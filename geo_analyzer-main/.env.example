# 2GIS API key
# Скопируй этот файл в .env и вставь реальный ключ.
DGIS_API_KEY=your_2gis_api_key_here

# Необязательные пути для Windows-сборки.
# Если оставить пустыми, данные будут сохраняться рядом с проектом / exe.
# GEO_ANALYZER_OUTPUT_DIR=C:\GeoAnalyzer\output
# GEO_ANALYZER_CACHE_DIR=C:\GeoAnalyzer\cache
# GEO_ANALYZER_BENCHMARK_DIR=C:\GeoAnalyzer\benchmarks

# Необязательные флаги.
# GEO_ANALYZER_NO_API=0
# GEO_ANALYZER_REFRESH_CACHE=0
# GEO_ANALYZER_REFRESH_CITY_BENCHMARK=0